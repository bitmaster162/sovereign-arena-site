<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sovereign Arena — открытая лаборатория алгоритмических гипотез</title>
  <meta name="description" content="150+ торговых ботов соревнуются на live-данных Binance. Paper trading. Логи публичны. Поражения публичны." />
  <style>
    :root { --bg:#05060f; --cyan:#00ffe1; --pink:#ff00ea; --gold:#ffd166; --text:#e8f6ff; }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:var(--bg); color:var(--text); font-family:'Inter',system-ui,sans-serif; line-height:1.55; }
    a { color:var(--cyan); }
    .wrap { max-width:1100px; margin:0 auto; padding:0 20px; }
    header { padding:80px 0 50px; text-align:center;
      background: radial-gradient(ellipse at 50% -20%, #1a0033 0%, #001a3d 45%, var(--bg) 80%); }
    h1 { font-size:clamp(34px,6vw,64px); font-weight:900; letter-spacing:2px;
      background:linear-gradient(90deg,var(--cyan),var(--pink)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
    .sub { margin:18px auto 0; max-width:680px; color:#9fdcff; font-size:18px; }
    .stats { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin:36px 0 8px; }
    .stat { background:#0c1428; border:1px solid #00ffe133; border-radius:14px; padding:16px 26px; min-width:150px; }
    .stat b { display:block; font-size:30px; color:var(--cyan); font-variant-numeric:tabular-nums; }
    .stat span { font-size:13px; color:#7fa8c9; }
    .cta-row { margin-top:34px; display:flex; gap:14px; justify-content:center; flex-wrap:wrap; }
    .btn { padding:13px 26px; border-radius:10px; font-weight:800; text-decoration:none; font-size:16px; }
    .btn-main { background:var(--cyan); color:#001a1a; box-shadow:0 0 30px #00ffe155; }
    .btn-ghost { border:1.5px solid var(--pink); color:var(--pink); }
    section { padding:56px 0; }
    h2 { font-size:28px; font-weight:900; letter-spacing:1px; margin-bottom:24px; }
    .grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:16px; }
    .card { background:#0c1428; border:1px solid #ffffff14; border-radius:16px; padding:22px; display:flex; flex-direction:column; gap:10px; }
    .card h3 { font-size:19px; }
    .card p { font-size:14.5px; color:#b9d4e8; flex:1; }
    .card a.cta { font-weight:700; font-size:14px; }
    .honest { background:#160a1e; border:1px solid #ff00ea44; border-radius:18px; padding:28px; }
    .honest h2 { color:var(--gold); }
    .honest p { color:#d9c2e8; margin-bottom:12px; }
    footer { padding:40px 0 60px; border-top:1px solid #ffffff12; color:#6f8fa8; font-size:13.5px; }
    footer a { color:#9fdcff; }
  </style>
</head>
<body>
  <header>
